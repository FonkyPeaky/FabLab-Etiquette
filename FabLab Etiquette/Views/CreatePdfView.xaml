<Window x:Class="FabLab_Etiquette.Views.CreatePdfView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Créer des étiquettes PDF — FabLab" Height="960" Width="1920"
        WindowState="Maximized"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Barre de statut en haut -->
        <Border DockPanel.Dock="Top" Background="#EEF2F7" BorderBrush="#CDD5DF"
                BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock x:Name="StatusBarText" FontSize="12" Foreground="#3A3A3A"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>   <!-- Panneau gauche : liste + propriétés -->
                <ColumnDefinition Width="*"/>      <!-- Canvas central -->
                <ColumnDefinition Width="220"/>    <!-- Panneau droit : actions -->
            </Grid.ColumnDefinitions>

            <!-- ========== PANNEAU GAUCHE ========== -->
            <DockPanel Grid.Column="0" Background="#F5F7FA" LastChildFill="True">
                <Border DockPanel.Dock="Top" Background="#3F5FA0" Padding="10,8">
                    <TextBlock Text="Étiquettes" Foreground="White" FontWeight="Bold" FontSize="14"/>
                </Border>

                <!-- Liste des étiquettes -->
                <ListBox x:Name="LabelListView"
                         DockPanel.Dock="Top"
                         ItemsSource="{Binding Labels}"
                         SelectedItem="{Binding SelectedLabel, Mode=TwoWay}"
                         SelectionMode="Extended"
                         SelectionChanged="OnLabelSelectionChanged"
                         Height="200" Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Text}" Width="140" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Width, StringFormat={}{0:0}}" Foreground="Gray" Width="40"/>
                                <TextBlock Text="×" Foreground="Gray"/>
                                <TextBlock Text="{Binding Height, StringFormat={}{0:0}}" Foreground="Gray" Width="40"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Propriétés de l'étiquette sélectionnée -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="Propriétés de l'étiquette" FontWeight="Bold"
                                   Margin="0,8,0,4" FontSize="13"/>
                        <Border Background="#E8F0FE" CornerRadius="3"
                                Padding="6,4" Margin="0,0,0,6"
                                Visibility="{Binding IsMultiSelect, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="11" Foreground="#3F5FA0" TextWrapping="Wrap"
                                       Text="{Binding SelectedLabels.Count, StringFormat={}{0} étiquettes sélectionnées — modifications appliquées à toutes.}"/>
                        </Border>

                        <TextBlock Text="Texte :" FontSize="11"/>
                        <TextBox Text="{Binding SelectedLabel.Text, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,8" TextWrapping="Wrap" AcceptsReturn="True" Height="50"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Largeur (mm) :" FontSize="11"/>
                                <TextBox Text="{Binding SelectedLabel.WidthInMillimeters, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.#}}"
                                         Margin="0,2,0,0" Height="26"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Hauteur (mm) :" FontSize="11"/>
                                <TextBox Text="{Binding SelectedLabel.HeightInMillimeters, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.#}}"
                                         Margin="0,2,0,0" Height="26"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Position X :" FontSize="11"/>
                                <TextBox Text="{Binding SelectedLabel.X, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,2,0,0" Height="26"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Position Y :" FontSize="11"/>
                                <TextBox Text="{Binding SelectedLabel.Y, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,2,0,0" Height="26"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Police :" FontSize="11"/>
                        <ComboBox SelectedItem="{Binding SelectedLabel.FontFamily, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,2,0,8" Height="28">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Arial</sys:String>
                                    <sys:String>Calibri</sys:String>
                                    <sys:String>Times New Roman</sys:String>
                                    <sys:String>Verdana</sys:String>
                                    <sys:String>Tahoma</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <TextBlock Text="Taille police :" FontSize="11"/>
                        <TextBox Text="{Binding SelectedLabel.FontSize, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,8" Height="26"/>

                        <TextBlock Text="Forme :" FontSize="11"/>
                        <ComboBox SelectedItem="{Binding SelectedLabel.Shape, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,2,0,8" Height="28">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Rectangle</sys:String>
                                    <sys:String>Ellipse</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <TextBlock Text="Action :" FontSize="11"/>
                        <ComboBox SelectedItem="{Binding SelectedLabel.Action, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,2,0,8" Height="28">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Découpe</sys:String>
                                    <sys:String>Gravure</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <TextBlock Text="Type / couleur d'étiquette :" FontSize="11"/>
                        <ComboBox x:Name="BackgroundColorComboBox"
                                  SelectionChanged="OnBackgroundColorChanged"
                                  Margin="0,2,0,8" Height="28">
                            <ComboBoxItem Content="Fond Blanc (#FFFFFF)" Tag="#FFFFFF"/>
                            <ComboBoxItem Content="Fond Noir (#000000)" Tag="#000000"/>
                            <ComboBoxItem Content="Fond Jaune (#FFFF00)" Tag="#FFFF00"/>
                            <ComboBoxItem Content="Fond Rouge (#FF0000)" Tag="#FF0000"/>
                            <ComboBoxItem Content="Fond Vert (#008000)" Tag="#008000"/>
                            <ComboBoxItem Content="Fond Bleu (#0000FF)" Tag="#0000FF"/>
                        </ComboBox>

                        <TextBlock Text="Note : le PDF exporté utilise uniquement rouge/noir pour la découpeuse laser."
                                   FontSize="10" Foreground="DarkOrange" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- ========== CANVAS CENTRAL ========== -->
            <DockPanel Grid.Column="1">
                <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,4" BorderBrush="#CCC" BorderThickness="0,0,0,1">
                    <TextBlock Text="Prévisualisation du plateau 600×300 mm  (aperçu en couleurs de fabrication)"
                               FontSize="11" Foreground="#555"/>
                </Border>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="PreviewCanvas"
                            Background="White"
                            Width="1700"
                            Height="850"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Margin="10"/>
                </ScrollViewer>
            </DockPanel>

            <!-- ========== PANNEAU DROIT ========== -->
            <DockPanel Grid.Column="2" Background="#F5F7FA" LastChildFill="False">
                <Border DockPanel.Dock="Top" Background="#3F5FA0" Padding="10,8">
                    <TextBlock Text="Actions" Foreground="White" FontWeight="Bold" FontSize="14"/>
                </Border>

                <StackPanel Margin="10" DockPanel.Dock="Top">
                    <TextBlock Text="Étiquettes" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Button Content="+ Ajouter" Command="{Binding AddLabelCommand}"
                            Margin="0,0,0,4" Height="32"/>
                    <Button Content="Dupliquer" Click="DuplicateLabel_Click"
                            Margin="0,0,0,4" Height="32"/>
                    <Button Content="✕ Supprimer" Click="DeleteLabel_Click"
                            Margin="0,0,0,12" Height="32"/>

                    <TextBlock Text="Disposition" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="→ Horizontal"
                                Command="{Binding ArrangeHorizontalCommand}"
                                Height="34" ToolTip="Réorganiser en lignes (gauche → droite)"/>
                        <Button Grid.Column="2" Content="↓ Vertical"
                                Command="{Binding ArrangeVerticalCommand}"
                                Height="34" ToolTip="Réorganiser en colonnes (haut → bas)"/>
                    </Grid>
                    <Button Content="Afficher grille" Command="{Binding ToggleGridCommand}"
                            Margin="0,0,0,12" Height="32"/>

                    <TextBlock Text="Image" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Button Content="Ajouter image" Click="OnAddImageClicked"
                            Margin="0,0,0,12" Height="32"/>

                    <Separator Margin="0,4,0,8"/>

                    <TextBlock Text="Projet" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Button Content="Sauvegarder projet" Click="SaveProject_Click"
                            Margin="0,0,0,4" Height="32"/>
                    <Button Content="Charger projet" Click="LoadProject_Click"
                            Margin="0,0,0,12" Height="32"/>

                    <Separator Margin="0,4,0,8"/>

                    <Button Content="Générer PDF" Command="{Binding GeneratePdfCommand}"
                            Height="44" FontWeight="Bold" Background="#3F5FA0" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
