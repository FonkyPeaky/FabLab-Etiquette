<Window x:Class="FabLab_Etiquette.Views.StandardizePdfView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standardisation du fichier PDF" Height="560" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <!-- Logos en fond -->
        <Image Source="/Assets/Logo_Orano.PNG" Opacity="0.07" HorizontalAlignment="Right"
               VerticalAlignment="Bottom" Width="160" Height="160" Margin="0,0,15,15"/>
        <Image Source="/Assets/Fablab_Logo.png" Opacity="0.07" HorizontalAlignment="Left"
               VerticalAlignment="Bottom" Width="130" Height="130" Margin="15,0,0,15"/>

        <StackPanel Margin="30">
            <TextBlock Text="Standardisation du fichier PDF" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Récapitulatif -->
            <Border BorderBrush="#CDD5DF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Récapitulatif" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Fichier source :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SourceFileName}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Demandeur :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryUserName}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Service :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryUserService}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Numéro :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryUserNumber}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Style :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SummaryStyle}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Couleur :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SummaryColor}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Impressions :" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SummaryPrintCount}" FontSize="11" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Titre :" FontSize="11" Foreground="Gray"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SummaryLabelTitle}" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Texte d'échantillon (extrait d'une étiquette) -->
            <TextBlock Text="Extrait du contenu (optionnel) :" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding SampleText, UpdateSourceTrigger=PropertyChanged}"
                     Height="28" Padding="4,4" Margin="0,0,0,4"/>
            <TextBlock Text="Quelques mots du texte des étiquettes — sera ajouté au nom du fichier."
                       FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

            <!-- Aperçu du nom de fichier -->
            <TextBlock Text="Nom de fichier généré :" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Border Background="#EEF2F7" CornerRadius="3" Padding="8,6" Margin="0,0,0,20">
                <TextBlock Text="{Binding PreviewFileName}" FontSize="11"
                           TextWrapping="Wrap" Foreground="#3A3A3A"/>
            </Border>

            <!-- Bouton standardiser -->
            <Button Content="Standardiser le fichier (copie + renommage)"
                    Command="{Binding StandardizeCommand}"
                    Height="40" FontWeight="Bold"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
